# ─── MCP Nexus Server Configuration ───
# Copy this file to .env and fill in your values.

# ─── SSH Connection ───
NEXUS_SSH_HOST=your-server-ip
NEXUS_SSH_PORT=22
NEXUS_SSH_USER=root
# Use SSH key (recommended) or password:
NEXUS_SSH_KEY_PATH=~/.ssh/id_rsa
# NEXUS_SSH_PASSWORD=your-ssh-password
NEXUS_SSH_POOL_SIZE=4

# ─── OAuth2 (optional — skip for local dev) ───
# NEXUS_OAUTH_CLIENT_ID=nexus-default
# NEXUS_OAUTH_CLIENT_SECRET=change-me-to-a-secure-secret

# ─── Server ───
NEXUS_HOST=0.0.0.0
NEXUS_PORT=8766
NEXUS_MCP_PATH=/mcp
NEXUS_LOG_LEVEL=info

# ─── Intelligence ───
NEXUS_INTELLIGENCE=true
NEXUS_DATA_DIR=~/.mcp-nexus

# ─── Database (optional — for db_query/db_execute tools) ───
# NEXUS_DB_HOST=localhost
# NEXUS_DB_PORT=5432
# NEXUS_DB_NAME=mydb
# NEXUS_DB_USER=myuser
# NEXUS_DB_PASSWORD=change-me

# ─── Rate Limiting ───
NEXUS_RATE_LIMIT_RPM=120
NEXUS_RATE_LIMIT_BURST=20

# ─── Watchdog (optional — monitors systemd services) ───
# NEXUS_WATCHDOG_SERVICES=nginx,postgresql
NEXUS_WATCHDOG_INTERVAL=30
NEXUS_MAX_RESTART_ATTEMPTS=10
NEXUS_RESTART_COOLDOWN=120
